# Backend Environment Variables for Vercel/Production
# Copy to .env and fill values. Add ALL to Vercel dashboard after deploy.

# Database (Required - use Neon.tech free Postgres)
DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=require
# OR individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=esteetade
DB_SSL=true

# JWT Auth (Required - generate with: openssl rand -hex 32)
JWT_SECRET=your-super-long-random-secret-key-here-min32chars

# Paystack Payments (Required for production)
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# Email (Required - use Gmail/Outlook App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FROM_EMAIL=Esteetade Travels <your-email@gmail.com>

# Wasabi/AWS S3 for uploads (Required)
WASABI_ACCESS_KEY_ID=your-access-key
WASABI_SECRET_ACCESS_KEY=your-secret-key
WASABI_BUCKET=your-bucket
WASABI_REGION=us-east-1  # or your region
WASABI_ENDPOINT=https://s3.wasabisys.com

# Frontend URL (for CORS/emails)
FRONTEND_URL=https://your-app.vercel.app

# Optional
NODE_ENV=production

