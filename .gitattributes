# Set the text attribute for all text files to automatically normalize line endings
* text=auto

# Explicitly binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary

# Ensure package-lock.json is normalized (text)
package-lock.json text eol=lf

